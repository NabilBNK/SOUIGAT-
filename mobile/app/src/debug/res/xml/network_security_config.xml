<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — DEBUG ONLY.
    Allows cleartext to localhost/emulator for local backend development.
    This file is NOT included in release/staging APKs.
-->
<network-security-config>
    <!-- Emulator → host machine (Docker backend at localhost:8000) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Physical device via adb reverse tcp:8000 tcp:8000 -->
        <domain includeSubdomains="false">localhost</domain>
        <!-- Add your own LAN IP here only if testing over Wi-Fi -->
        <!-- <domain includeSubdomains="false">192.168.x.x</domain> -->
    </domain-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

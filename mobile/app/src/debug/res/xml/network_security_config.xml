<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config - DEBUG ONLY.
    Allows cleartext traffic to debug backends on the local LAN.
    This file is NOT included in release/staging APKs.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

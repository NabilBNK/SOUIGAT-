<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — release/staging builds.
    Cleartext is denied everywhere. Debug-specific overrides are in src/debug/res/xml/.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

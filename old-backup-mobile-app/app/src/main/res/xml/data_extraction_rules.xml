<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ backup.
    Excludes sensitive files from device-to-device transfers.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="souigat_secure_prefs.xml" />
        <exclude domain="database" path="souigat.db" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="souigat_secure_prefs.xml" />
        <exclude domain="database" path="souigat.db" />
    </device-transfer>
</data-extraction-rules>
